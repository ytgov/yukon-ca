<?php

/**
 * @file
 * Yukon Moderation module.
 *
 * Provides moderation features for the Yukon project.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\yukon_moderation\EventSubscriber\CoordinatedPublicationSubscriber;

/**
 * Implements hook_form_alter().
 */
function yukon_moderation_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Check if the form ID matches the pattern for node edit forms.
  if (strpos($form_id, 'node_') === 0) {
    // Set the visibility state for the field_publisher element.
    $form['field_editor_publisher']['#states'] = [
      'visible' => [
        ':input[name="moderation_state[0][state]"]' => ['value' => 'needs_review'],
      ],
    ];
    $form['field_publisher']['#states'] = [
      'visible' => [
        ':input[name="moderation_state[0][state]"]' => ['value' => 'ready_to_publish'],
      ],
    ];
  }
}

/**
 * Implements hook_field_widget_complete_form_alter().
 */
function yukon_moderation_field_widget_complete_form_alter(array &$field_widget_complete_form, FormStateInterface $form_state, array $context) {
  // Only act on the moderation_state field.
  if ($context['items']->getFieldDefinition()->getName() !== 'moderation_state') {
    return;
  }
  // Remove the "Ready for Coordinated Publication" option from the default
  // (English) translation form. This state is only meaningful for
  // non-default language translations.
  $entity = $context['items']->getEntity();
  if (!$entity->isDefaultTranslation()) {
    return;
  }
  if (isset($field_widget_complete_form['widget'][0]['state']['#options']['ready_for_coordinated_publication'])) {
    unset($field_widget_complete_form['widget'][0]['state']['#options']['ready_for_coordinated_publication']);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for content_moderation_entity_moderation_form.
 */
function yukon_moderation_form_content_moderation_entity_moderation_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  // Retrieve the entity passed to EntityModerationForm::buildForm().
  $args = $form_state->getBuildInfo()['args'];
  if (empty($args[0]) || !$args[0] instanceof EntityInterface) {
    return;
  }
  // Remove the "Ready for Coordinated Publication" transition from the default
  // (English) translation's moderation block. This state is only meaningful
  // for non-default language translations.
  if (!$args[0]->isDefaultTranslation()) {
    return;
  }
  unset($form['new_state']['#options']['ready_for_coordinated_publication']);
}

/**
 * Implements hook_entity_update().
 *
 * Tracks when a non-default translation of a node enters or leaves the
 * "Ready for Coordinated Publication" moderation state, using the State API.
 *
 * This hook operates on content_moderation_state entities, which are saved
 * separately per translation and carry the correct langcode on their active
 * translation — unlike the workbench_email event shim, which always dispatches
 * events with the default (English) node translation.
 *
 * workbench_email moves its hook_entity_update to the end of the invocation
 * order, so this hook fires before the event is dispatched. That means the
 * flag is set/cleared before the subscriber checks it.
 */
function yukon_moderation_entity_update(EntityInterface $entity) {
  // Only interested in content_moderation_state entities for nodes.
  if ($entity->getEntityTypeId() !== 'content_moderation_state') {
    return;
  }
  if ($entity->get('content_entity_type_id')->value !== 'node') {
    return;
  }
  // Only non-default translations have a coordinated publication state.
  if ($entity->isDefaultTranslation()) {
    return;
  }

  $langcode = $entity->language()->getId();
  $new_state = $entity->moderation_state->value;
  $node_id = $entity->get('content_entity_id')->value;
  $key = CoordinatedPublicationSubscriber::STATE_KEY_PREFIX . $node_id . '.' . $langcode;

  if ($new_state === CoordinatedPublicationSubscriber::COORDINATED_STATE) {
    // Store the node revision ID so the subscriber can load the correct French
    // content when auto-publishing. The translator may have edited content in
    // the same save that moved the state to rfcp.
    $node_revision_id = $entity->get('content_entity_revision_id')->value;
    \Drupal::state()->set($key, $node_revision_id);
  }
  else {
    \Drupal::state()->delete($key);
  }
}

/**
 * Implements hook_preprocess_html().
 */
function yukon_moderation_preprocess_html(&$variables) {
  $route_name = \Drupal::routeMatch()->getRouteName();

  // Add specific body class for our all revisions page.
  if ($route_name == 'yukon_moderation.node_all_revisions') {
    $variables['attributes']['class'][] = 'page-node-all-revisions';
  }

  // Add specific body class for our comparison page.
  if ($route_name == 'yukon_moderation.compare_revisions') {
    $variables['attributes']['class'][] = 'page-yukon-moderation-compare-revisions';
  }
}
